pipeline {
    agent any

    environment {
        IMAGE_NAME = "ss-table"
        DOCKER_REGISTRY = "divyansh"
        SONAR_HOST = "http://51.20.138.150:9000"
        
        // 1. Manually specify your local Java 23 paths here to prevent tool lookup bugs
        JAVA_HOME = "/usr/lib/jvm/temurin-23-jdk-amd64"
        PATH = "/usr/lib/jvm/temurin-23-jdk-amd64/bin:${env.PATH}"

        KUBE_CRED_ID = "KUBERNETES_SECRET"
    }

    stages {

        // ---------------- BUILD ----------------
        stage('Build + Test + Package') {
            steps {
                // Verified your local Java installation path is tracked correctly
                sh 'java -version'
                sh 'mvn clean verify package'
            }

            post {
                success {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                    stash name: 'classes', includes: 'target/classes/**'
                    stash name: 'jar', includes: 'target/*.jar'
                }
            }
        }

        // ---------------- SONAR ----------------
        stage('SonarQube Analysis') {
            steps {
                unstash 'classes'
                withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {
                    sh """
                        mvn sonar:sonar \
                        -Dsonar.projectKey=ss-table \
                        -Dsonar.host.url=${SONAR_HOST} \
                        -Dsonar.login=${SONAR_TOKEN} \
                        -Dsonar.java.binaries=target/classes
                    """
                }
            }
        }

        // ---------------- DOCKER BUILD ----------------
        stage('Docker Build') {
            steps {
                unstash 'jar'
                sh "docker build -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:latest ."
            }
        }

        // ---------------- CLEAN OLD JOB ----------------
        stage('Clean Old Kubernetes Job') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    sh """
                        echo "Deleting previous job if exists..."
                        kubectl delete job ss-table --ignore-not-found=true
                    """
                }
            }
        }

        // ---------------- LOAD IMAGE ----------------
        stage('Load Image into Minikube') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    // FORCE minikube to look at the ubuntu user's profile state
                    sh "sudo -u ubuntu minikube image load ${DOCKER_REGISTRY}/${IMAGE_NAME}:latest"
                    // sh "minikube image load ${DOCKER_REGISTRY}/${IMAGE_NAME}:latest"
                }
            }
        }

        // ---------------- DEPLOY ----------------
        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    sh """
                        kubectl apply -f k8s/
                        kubectl get jobs
                        kubectl get pods
                    """
                }
            }
        }

        // ---------------- WAIT FOR JOB ----------------
        stage('Wait for Job Completion') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    sh "kubectl wait --for=condition=complete job/ss-table --timeout=300s"
                }
            }
        }

        // ---------------- SHOW LOGS ----------------
        stage('Show Job Logs') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    sh """
                        echo "=== JOB LOGS ==="
                        kubectl logs job/ss-table
                    """
                }
            }
        }
    }

    // ---------------- FAILURE DEBUGGING ----------------
    post {
        failure {
            withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                sh """
                    echo "=== JOB STATUS ==="
                    kubectl get jobs || true
    
                    echo "=== PODS ==="
                    kubectl get pods -o wide || true
    
                    echo "=== DESCRIBE JOB ==="
                    kubectl describe job ss-table || true
    
                    echo "=== DESCRIBE PODS ==="
                    kubectl describe pods -l job-name=ss-table || true
    
                    echo "=== POD LOGS ==="
                    kubectl logs -l job-name=ss-table || true
                """
            }
        }
    }
}

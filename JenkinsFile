pipeline {
    agent any

    environment {
        IMAGE_NAME = "ss-table"
        DOCKER_REGISTRY = "divyansh"
        SONAR_HOST = "http://51.20.138.150:9000"
        
        // Java configurations
        JAVA_HOME = "/usr/lib/jvm/temurin-23-jdk-amd64"
        PATH = "/usr/lib/jvm/temurin-23-jdk-amd64/bin:${env.PATH}"
        
        // Change this to match the EXACT Credentials ID you see in Jenkins UI
        KUBE_CRED_ID = "KUBERNETES_SECRET" 
    }

    stages {

        // ---------------- BUILD ----------------
        stage('Build + Test + Package') {
            steps {
                sh 'java -version'
                sh 'mvn clean verify package'
            }
            post {
                success {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                    stash name: 'classes', includes: 'target/classes/**'
                    stash name: 'jar', includes: 'target/*.jar'
                }
            }
        }

        // ---------------- SONAR ----------------
        stage('SonarQube Analysis') {
            steps {
                unstash 'classes'
                withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {
                    sh """
                        mvn sonar:sonar \
                        -Dsonar.projectKey=ss-table \
                        -Dsonar.host.url=${SONAR_HOST} \
                        -Dsonar.login=${SONAR_TOKEN} \
                        -Dsonar.java.binaries=target/classes
                    """
                }
            }
        }

        // ---------------- DOCKER BUILD ----------------
        stage('Docker Build') {
            steps {
                unstash 'jar'
                sh "docker build -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:latest ."
            }
        }

        // ---------------- KUBERNETES DEPLOYMENT SEQUENCE ----------------
        // We use withCredentials to safely inject the kube/config file context dynamically
        stage('Kubernetes Operations') {
            steps {
                withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                    sh """
                        echo "=== Verified Cluster Connection ==="
                        kubectl cluster-info

                        echo "Deleting previous job if exists..."
                        kubectl delete job ss-table --ignore-not-found=true

                        echo "Loading Image into Minikube..."
                        MINIKUBE_HOME=/home/ubuntu minikube image load ${DOCKER_REGISTRY}/${IMAGE_NAME}:latest

                        echo "Deploying to Kubernetes..."
                        kubectl apply -f k8s/
                        kubectl get jobs
                        kubectl get pods

                        echo "Waiting for Job Completion..."
                        kubectl wait --for=condition=complete job/ss-table --timeout=300s

                        echo "=== JOB LOGS ==="
                        kubectl logs job/ss-table
                    """
                }
            }
        }
    }

    // ---------------- FAILURE DEBUGGING ----------------
    post {
        failure {
            // We use the same credential here so the debugging commands can also talk to the cluster
            withCredentials([file(credentialsId: "${KUBE_CRED_ID}", variable: 'KUBECONFIG')]) {
                sh """
                    echo "=== JOB STATUS ==="
                    kubectl get jobs || true

                    echo "=== PODS ==="
                    kubectl get pods -o wide || true

                    echo "=== DESCRIBE JOB ==="
                    kubectl describe job ss-table || true

                    echo "=== DESCRIBE PODS ==="
                    kubectl describe pods -l job-name=ss-table || true

                    echo "=== POD LOGS ==="
                    kubectl logs -l job-name=ss-table || true
                """
            }
        }
    }
}

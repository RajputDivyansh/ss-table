pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: maven
    image: maven:3.9.9-eclipse-temurin-23
    command: ["cat"]
    tty: true
'''
        }
    }

    environment {
        MAVEN_OPTS = "-Xmx1024m"
    }

    stages {
        stage('Check Versions') {
            steps {
                container('maven') {
                    sh 'java -version'
                    sh 'mvn -version'
                }
            }
        }

        stage('Build') {
            steps {
                container('maven') {
                    // No apt-get update needed anymore!
                    sh 'mvn clean package'
                }
            }
        }
    }

    post {
        success {
            echo "Build successful 🚀"
        }
        failure {
            echo "Build failed ❌"
        }
    }
}
